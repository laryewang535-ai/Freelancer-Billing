# ─── 应用 ───────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── 数据库（PostgreSQL）────────────────────────────
# 本地示例：postgresql://postgres:password@localhost:5432/freelancer_billing
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/freelancer_billing?schema=public

# ─── Auth.js（阶段 3 启用）──────────────────────────
AUTH_SECRET=generate_with_openssl_rand_base64_32
AUTH_URL=http://localhost:3000

# Google 登录（Google Cloud Console → OAuth 2.0 客户端）
# 重定向 URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub 登录（可选）
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Resend 平台统一发信（所有登录用户共用）──────────
# 注册 https://resend.com → API Keys
# 本地测试: RESEND_FROM_EMAIL=onboarding@resend.dev（仅可发到 Resend 账号邮箱）
# 生产: 验证域名后使用 invoices@yourdomain.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Freelancer Billing
RESEND_WEBHOOK_SECRET=

# ─── Lemon Squeezy 订阅（托管 Checkout）────────────────
# 1. 注册 https://app.lemonsqueezy.com → Settings → API 创建 API Key
# 2. 创建 Store，添加 Pro ($9/月) 和 Business ($29/月) 订阅产品
# 3. 填入 Store ID、各 Variant ID（产品页 URL 或 API 可见）
# 4. Webhook: https://你的域名/api/webhooks/lemonsqueezy
#    事件: subscription_created, subscription_updated, subscription_cancelled, subscription_expired
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_PRO=
LEMONSQUEEZY_VARIANT_BUSINESS=
LEMONSQUEEZY_WEBHOOK_SECRET=

# ─── Cloudflare R2（阶段 6 PDF）─────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=freelancer-billing
R2_PUBLIC_URL=

# ─── OpenAI（阶段 10）───────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.5
# 本地 Clash/V2Ray 等 HTTP 代理（常见 http://127.0.0.1:7890；留空则不走代理）
OPENAI_HTTP_PROXY=
# 也可使用 OpenAI 兼容中转（须以 /v1 结尾，与 HTTP 代理二选一或同时配置）
# OPENAI_BASE_URL=https://your-openai-proxy.example.com/v1

# ─── Vercel Cron 鉴权 ───────────────────────────────
CRON_SECRET=
